# Doxygen configuration for SHT3x
# Generated and maintained for unified API documentation.

PROJECT_NAME           = "SHT3x"
PROJECT_NUMBER         = "1.7.0"
PROJECT_BRIEF          = "Framework-neutral SHT3x driver API documentation"
OUTPUT_DIRECTORY       = .doxygen
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = NO
OUTPUT_LANGUAGE        = English

MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 3
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_FRIEND_COMPOUNDS  = NO

SHOW_INCLUDE_FILES     = YES
INLINE_INFO            = YES
SOURCE_BROWSER         = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
STRIP_CODE_COMMENTS    = NO

INPUT                  = README.md CHANGELOG.md include \
                         docs/hardware.md \
                         docs/esp-idf.md \
                         docs/TUNNELMONITOR_NODE_SUITABILITY_AUDIT.md \
                         docs/reference/sht3x-chip-notes.md \
                         docs/reports/hil-validation-COM20-20260629.md
FILE_PATTERNS          = *.h *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */.pio/* */.git/* */test/* */.doxygen/* \
                         */docs/doxygen/*
EXAMPLE_PATH           = examples/01_basic_bringup_cli

USE_MDFILE_AS_MAINPAGE = README.md
FULL_PATH_NAMES        = NO
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
SORT_MEMBERS_CTORS_1ST = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_COLORSTYLE        = AUTO_LIGHT
GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO

WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = YES
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = YES
QUIET                  = YES
