# Doxygen configuration for SHT3x
# Generated and maintained for unified API documentation.

PROJECT_NAME           = "SHT3x"
PROJECT_NUMBER         = "1.5.0"
PROJECT_BRIEF          = "Framework-neutral SHT3x driver API documentation"
OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = NO
OUTPUT_LANGUAGE        = English

MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 3
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_FRIEND_COMPOUNDS  = NO

SHOW_INCLUDE_FILES     = YES
INLINE_INFO            = YES
SOURCE_BROWSER         = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
STRIP_CODE_COMMENTS    = NO

INPUT                  = README.md CHANGELOG.md include \
                         docs/README.md \
                         docs/IDF_PORT.md \
                         docs/IDF_PORT_IMPLEMENTATION.md \
                         docs/HARDWARE_VALIDATION.md \
                         docs/SHT3X_HARDWARE_VALIDATION_MATRIX.md \
                         docs/SHT3X_HIL_RUNBOOK.md \
                         docs/SHT3X_HIL_LOG_TEMPLATE.md \
                         docs/SHT3X_I2C_HIL_RUNBOOK.md \
                         docs/SHT3X_I2C_HIL_TARGET_TEMPLATE.md \
                         docs/SHT3X_I2C_HIL_SELFTEST_REPORT.md \
                         docs/SHT3X_ALERT_STATUS_FIX_REPORT.md \
                         docs/SHT3X_CORE_CONTRACTS_PARTIAL_STATE_REPORT.md \
                         docs/SHT3X_PROMPTS_00_05_AUDITOR_SUMMARY.md
FILE_PATTERNS          = *.h *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */.pio/* */.git/* */test/* */docs/doxygen/* */docs/extracted-md/* */docs/pdf-extracted-md/* */docs/_pdf_extracts/*
EXAMPLE_PATH           = examples/01_basic_bringup_cli

USE_MDFILE_AS_MAINPAGE = README.md
FULL_PATH_NAMES        = NO
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
SORT_MEMBERS_CTORS_1ST = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_COLORSTYLE        = AUTO_LIGHT
GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO

WARN_IF_UNDOCUMENTED   = NO
WARN_NO_PARAMDOC       = YES
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = NO
QUIET                  = YES
