{
  "name": "SHT3x",
  "version": "1.6.0",
  "description": "Deterministic SHT3x temperature/humidity sensor driver for ESP32.",
  "keywords": [
    "sht3x",
    "sht30",
    "sht31",
    "sht35",
    "sensor",
    "temperature",
    "humidity",
    "i2c",
    "esp32",
    "arduino",
    "platformio"
  ],
  "authors": [
    {
      "name": "Thymos Solution s.r.o",
      "email": "info@thymos.cz",
      "url": "https://www.thymos.cz"
    },
    {
      "name": "Jan Havelka",
      "email": "info@thymos.cz",
      "url": "https://www.thymos.cz",
      "maintainer": true
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/janhavelka/SHT3x-main.git"
  },
  "license": "MIT",
  "homepage": "https://www.thymos.cz",
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "platforms": [
    "espressif32"
  ],
  "headers": [
    "SHT3x/SHT3x.h"
  ],
  "build": {
    "includeDir": "include",
    "srcDir": "src"
  },
  "export": {
    "include": [
      "include/**",
      "src/**",
      "examples/**",
      "README.md",
      "CHANGELOG.md",
      "LICENSE",
      "library.json",
      "idf_component.yml",
      "CMakeLists.txt",
      "docs/README.md",
      "docs/HARDWARE_VALIDATION.md",
      "docs/SHT3X_HARDWARE_VALIDATION_MATRIX.md",
      "docs/SHT3X_HIL_RUNBOOK.md",
      "docs/SHT3X_HIL_LOG_TEMPLATE.md",
      "docs/SHT3X_I2C_HIL_RUNBOOK.md",
      "docs/SHT3X_I2C_HIL_TARGET_TEMPLATE.md",
      "docs/SHT3X_I2C_HIL_SELFTEST_REPORT.md",
      "docs/hil/20260601_arduino_esp32s3_com17_7847ed0_default_hil.md",
      "docs/IDF_PORT.md",
      "docs/IDF_PORT_IMPLEMENTATION.md",
      "docs/rationale/SHT3X_ALERT_ENCODING_FIX_REPORT.md",
      "docs/rationale/SHT3X_ALERT_STATUS_FIX_REPORT.md",
      "docs/rationale/SHT3X_API_CONTRACT_CLEANUP_REPORT.md",
      "docs/rationale/SHT3X_CORE_CONTRACTS_PARTIAL_STATE_REPORT.md",
      "tools/run_sht3x_hil.py",
      "tools/run_i2c_hil.py"
    ],
    "exclude": [
      ".github/**",
      ".idea/**",
      ".pio/**",
      ".pioignore",
      ".vscode/**",
      "build/**",
      "examples/idf/basic/build/**",
      "examples/idf/basic/sdkconfig",
      "examples/idf/basic/sdkconfig.old",
      "examples/idf/basic/dependencies.lock",
      "examples/idf/basic/managed_components/**",
      "examples/idf/basic/compile_commands.json",
      "hil_logs/**",
      "test/**",
      "*.tar",
      "*.tar.gz",
      "*.tgz",
      "*.zip",
      "docs/**/*.pdf",
      "docs/**/*.xlsx",
      "docs/archive/**",
      "docs/doxygen/**",
      "docs/reference/**"
    ]
  }
}
